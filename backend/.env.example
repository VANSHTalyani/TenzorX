APP_ENV=development
APP_NAME=poonawalla-loan-wizard
LOG_LEVEL=INFO
SECRET_KEY=change-me-to-a-long-random-string-in-production
CORS_ORIGINS=["http://localhost:3000"]

POSTGRES_DSN=postgresql+asyncpg://loan:loan@postgres:5432/loanwizard

OLLAMA_BASE_URL=http://ollama:11434
# Must match a name from `ollama list` exactly (e.g. qwen2.5:7b-instruct or qwen2.5:7b).
# If you see HTTP 404 from Ollama, run: ollama pull <this value>
OLLAMA_MODEL=qwen2.5:7b-instruct
LLM_TIMEOUT_SECONDS=60

WHISPER_MODEL_SIZE=base
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
WHISPER_LANGUAGE=en
STT_MAX_CONCURRENT=4

VISION_BACKEND=deepface
VISION_AGE_TOLERANCE_YEARS=7

MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=loan-wizard-recordings
MINIO_SECURE=false

POLICY_MIN_AGE=21
POLICY_MAX_AGE=65
POLICY_MIN_INCOME_MONTHLY=20000
POLICY_MAX_LOAN_AMOUNT=2500000
POLICY_MIN_LOAN_AMOUNT=50000

RISK_MODEL_PATH=/app/data/models/risk_xgb.json
RISK_MODEL_FEATURES_PATH=/app/data/models/risk_features.json
